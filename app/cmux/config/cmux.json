{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "app": {
    "appearance": "dark",
    "windowTitleTemplate": "SPIN - {activeWorkspace}",
    "hideWorkspaceTitleBar": false,
    "keepWorkspaceOpenWhenClosingLastSurface": true
  },
  "sidebar": {
    "showWorkspaceDescription": true,
    "wrapWorkspaceTitles": false,
    "showNotifications": true,
    "showPorts": true,
    "showPullRequests": true
  },
  "sidebarAppearance": {
    "matchTerminalBackground": false,
    "tintColor": "#FF2BD6",
    "lightModeTintColor": "#FFD1F5",
    "darkModeTintColor": "#FF2BD6",
    "tintOpacity": 0.62
  },
  "workspaceColors": {
    "indicatorStyle": "washRail",
    "selectionColor": "#7A005F",
    "notificationBadgeColor": "#00E5FF",
    "colors": {
      "SPIN Neon Pink": "#FF2BD6",
      "SPIN Electric Cyan": "#00E5FF",
      "SPIN Laser Green": "#39FF14",
      "SPIN Gold": "#EAB308",
      "SPIN Violet": "#A855F7",
      "SPIN Red": "#EF4444"
    }
  },
  "workspaceGroups": {
    "newWorkspacePlacement": "afterCurrent",
    "byCwd": {
      "~": {
        "color": "#0E6B8C",
        "icon": "circle.hexagongrid.fill"
      }
    }
  },
  "customSidebars": {
    "renderer": "remote"
  }
}
