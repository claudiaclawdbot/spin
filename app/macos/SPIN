#!/usr/bin/env bash
set -uo pipefail

MACOS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
CONTENTS_DIR="$(cd "$MACOS_DIR/.." >/dev/null 2>&1 && pwd)"
RESOURCES_DIR="$CONTENTS_DIR/Resources"
APP_SUPPORT_ROOT="${SPIN_APP_HOME:-$HOME/Library/Application Support/SPIN}"
RUNTIME_DIR="$APP_SUPPORT_ROOT/runtime"
LOG_DIR="$APP_SUPPORT_ROOT/logs"

export SPIN_APP_RESOURCES="$RESOURCES_DIR"
export SPIN_INTERNAL_BIN_DIR="$RESOURCES_DIR/bin"
export SPIN_BUNDLED_RUNTIME="$RESOURCES_DIR/runtime"
export SPIN_ROOT="$RUNTIME_DIR"
export WORKSPACE_ROOT="$SPIN_ROOT"
export PATH="$SPIN_INTERNAL_BIN_DIR:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

SOCKET_DIR="${SPIN_CMUX_SOCKET_DIR:-$HOME/.local/state/cmux}"
mkdir -p "$SOCKET_DIR"
export CMUX_SOCKET_PATH="${CMUX_SOCKET_PATH:-$SOCKET_DIR/spin.sock}"
export CMUX_ALLOW_SOCKET_OVERRIDE="${CMUX_ALLOW_SOCKET_OVERRIDE:-1}"
export CMUX_SOCKET_ENABLE="${CMUX_SOCKET_ENABLE:-1}"
export CMUX_SOCKET_MODE="${CMUX_SOCKET_MODE:-allowall}"
export CMUX_BUNDLED_CLI_PATH="$SPIN_INTERNAL_BIN_DIR/cmux"

if [ "${SPIN_APP_LAUNCH_DRY_RUN:-0}" != "1" ] && [ "${SPIN_APP_NO_LOG_REDIRECT:-0}" != "1" ]; then
  mkdir -p "$LOG_DIR"
  exec >> "$LOG_DIR/app-launch.log" 2>&1
  printf '\n[%s] SPIN.app launch\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf 'runtime=%s\nresources=%s\nsocket=%s\n' "$SPIN_ROOT" "$SPIN_APP_RESOURCES" "$CMUX_SOCKET_PATH"
fi

copy_runtime() {
  mkdir -p "$APP_SUPPORT_ROOT"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete \
      --exclude '/org' \
      --exclude '/logs' \
      --exclude '/projects' \
      --exclude '/dist' \
      --exclude '/vendor/sources' \
      "$SPIN_BUNDLED_RUNTIME"/ "$RUNTIME_DIR"/
  else
    mkdir -p "$RUNTIME_DIR"
    (cd "$SPIN_BUNDLED_RUNTIME" && tar --exclude './org' --exclude './logs' --exclude './projects' --exclude './dist' --exclude './vendor/sources' -cf - .) \
      | (cd "$RUNTIME_DIR" && tar -xf -)
  fi
}

seed_org_if_missing() {
  if [ ! -d "$RUNTIME_DIR/org" ]; then
    mkdir -p "$RUNTIME_DIR"
    if [ -d "$SPIN_BUNDLED_RUNTIME/org" ]; then
      (cd "$SPIN_BUNDLED_RUNTIME" && tar -cf - org) | (cd "$RUNTIME_DIR" && tar -xf -)
    fi
  fi
}

seed_action_policy() {
  local source="$SPIN_BUNDLED_RUNTIME/org/ACTION_POLICY.example.json"
  local target="$RUNTIME_DIR/org/ACTION_POLICY.json"
  mkdir -p "$RUNTIME_DIR/org/action-broker/receipts"
  if [ ! -f "$target" ] && [ -f "$source" ]; then
    cp "$source" "$target"
    chmod 600 "$target" 2>/dev/null || true
  fi
}

seed_file_if_spin_managed() {
  local source="$1" target="$2" match="$3" fallback_match="${4:-}" target_dir backup
  [ -f "$source" ] || return 0
  target_dir="$(dirname "$target")"
  mkdir -p "$target_dir"
  if [ ! -s "$target" ]; then
    cp "$source" "$target"
    chmod 600 "$target" 2>/dev/null || true
    return 0
  fi
  cmp -s "$source" "$target" && return 0
  if grep -Fq "$match" "$target" 2>/dev/null || { [ -n "$fallback_match" ] && grep -Fq "$fallback_match" "$target" 2>/dev/null; }; then
    backup="$target.spin-backup-$(date -u +%Y%m%dT%H%M%SZ)"
    cp "$target" "$backup" 2>/dev/null || true
    cp "$source" "$target"
    chmod 600 "$target" 2>/dev/null || true
  fi
}

seed_cmux_defaults() {
  [ "${SPIN_APP_SKIP_CMUX_CONFIG_SEED:-0}" = "1" ] && return 0
  local config_src dock_src sidebar_src config_dir sidebar_dir
  config_src="$RESOURCES_DIR/app/cmux/config/cmux.json"
  dock_src="$RESOURCES_DIR/app/cmux/config/dock.json"
  sidebar_src="$RESOURCES_DIR/app/cmux/sidebars/spin-navigator.swift"
  [ -f "$config_src" ] || config_src="$RUNTIME_DIR/app/cmux/config/cmux.json"
  [ -f "$dock_src" ] || dock_src="$RUNTIME_DIR/app/cmux/config/dock.json"
  [ -f "$sidebar_src" ] || sidebar_src="$RUNTIME_DIR/app/cmux/sidebars/spin-navigator.swift"

  config_dir="$HOME/.config/cmux"
  sidebar_dir="$config_dir/sidebars"
  seed_file_if_spin_managed "$config_src" "$config_dir/cmux.json" '"SPIN - {activeWorkspace}"' 'cmux creates this template on launch'
  seed_file_if_spin_managed "$dock_src" "$config_dir/dock.json" '"SPIN Status"'
  seed_file_if_spin_managed "$sidebar_src" "$sidebar_dir/spin-navigator.swift" 'Text("SPIN")'
}

seed_cmux_user_defaults() {
  [ "${SPIN_APP_SKIP_CMUX_DEFAULTS_SEED:-0}" = "1" ] && return 0
  [ "$(uname -s)" = "Darwin" ] || return 0
  [ -x /usr/libexec/PlistBuddy ] || return 0

  # SPIN owns the left rail. Seed both bundle ids so old developer builds and
  # SPIN-branded release builds select the Navigator sidebar before cmux opens.
  local domain plist prefs_dir
  for domain in dev.spin.app com.cmuxterm.app; do
    prefs_dir="$HOME/Library/Preferences"
    plist="$prefs_dir/$domain.plist"
    mkdir -p "$prefs_dir"
    if [ ! -f "$plist" ]; then
      cat > "$plist" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict/>
</plist>
EOF
    fi
    /usr/libexec/PlistBuddy -c "Delete :customSidebars.beta.enabled" "$plist" >/dev/null 2>&1 || true
    /usr/libexec/PlistBuddy -c "Add :customSidebars.beta.enabled bool true" "$plist" >/dev/null 2>&1 || true
    /usr/libexec/PlistBuddy -c "Delete :cmuxExtensionSidebar.providerId" "$plist" >/dev/null 2>&1 || true
    /usr/libexec/PlistBuddy -c "Add :cmuxExtensionSidebar.providerId string cmux.sidebar.custom.spin-navigator" "$plist" >/dev/null 2>&1 || true
    chmod 600 "$plist" 2>/dev/null || true
    if [ -z "${SPIN_APP_HOME:-}" ] && command -v defaults >/dev/null 2>&1; then
      defaults write "$domain" customSidebars.beta.enabled -bool true >/dev/null 2>&1 || true
      defaults write "$domain" cmuxExtensionSidebar.providerId "cmux.sidebar.custom.spin-navigator" >/dev/null 2>&1 || true
    fi
  done
}

copy_runtime
seed_org_if_missing
seed_action_policy
seed_cmux_defaults
seed_cmux_user_defaults

exec "$SPIN_ROOT/scripts/spin" app-launch
